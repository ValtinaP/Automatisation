# Get these at https://my.telegram.org -> API development tools
TG_API_ID=
TG_API_HASH=

# Name of the local session file (no extension), created on first login
TG_SESSION_NAME=news_parser_session

# https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

# Username or numeric id of the private channel where matches get posted.
# Create a private channel, add this same Telegram account to it, then put
# its @username (with @) or numeric id here.
NOTIFY_CHANNEL=
